{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "CUSTOM",
    "buildCommand": "cd client && npm install && npm run build && cd .. && npm install",
    "startCommand": "node server.js"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyAmount": 5
  }
}